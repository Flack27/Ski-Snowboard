# ─────────────────────────────────────────────────────────────
# Spapens Ski & Snowboard — environment
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, OG, Mollie redirect)
NEXT_PUBLIC_SITE_URL=https://waxen-en-slijpen-hilvarenbeek.nl

# PocketBase — internal URL is used by the Next server (docker network),
# the public URL is used for <img> file links and the admin dashboard.
POCKETBASE_URL=http://pocketbase:8090
NEXT_PUBLIC_POCKETBASE_URL=https://beheer.waxen-en-slijpen-hilvarenbeek.nl

# PocketBase superuser (server-side writes: orders, bookings). Set once.
POCKETBASE_ADMIN_EMAIL=admin@waxen-en-slijpen-hilvarenbeek.nl
POCKETBASE_ADMIN_PASSWORD=change-me-long-random
# Encryption key for PocketBase settings at rest (32+ chars)
PB_ENCRYPTION_KEY=change-me-32-char-random-string

# Mollie (online payments): the key is set in the PocketBase admin
# (payment_settings.mollie_api_key), NOT here — online is off by default.

# Resend transactional email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="Spapens Ski & Snowboard <info@waxen-en-slijpen-hilvarenbeek.nl>"
MAIL_OWNER=info@waxen-en-slijpen-hilvarenbeek.nl

# On-demand revalidation — shared secret between PocketBase hook and Next
REVALIDATE_SECRET=change-me-long-random

# Cloudflare Turnstile (spam protection on contact + booking forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reviews — star rating + link to the listing.
# Place ID is public (builds the "read reviews" link + fetches rating).
# The Maps API key is a server secret (leave empty to show the static fallback rating).
NEXT_PUBLIC_GOOGLE_PLACE_ID=
GOOGLE_MAPS_API_KEY=
